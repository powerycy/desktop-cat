{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Cat",
  "version": "0.1.0",
  "identifier": "com.desktopcat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "Desktop Cat",
        "width": 150,
        "height": 150,
        "minWidth": 80,
        "minHeight": 80,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "url": "/"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/presets/**/*": "presets/",
      "resources/sprites/зҲұеқӨ/*": "sprites/зҲұеқӨ/",
      "resources/sprites/жҡҙиәҒе–ө/*": "sprites/жҡҙиәҒе–ө/",
      "icons/32x32.png": "tray-icon.png"
    }
  }
}
